PORT=8787
DEVICE=BlackHole 2ch
MIC=MacBook Pro Microphone

# OpenAI Configuration (Primary models)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_SUMMARY_MODEL=gpt-4o

# OpenRouter Configuration (Fallback for both transcription and summarization)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_TRANSCRIBE_MODEL=openai/whisper-large-v3-turbo
OPENROUTER_SUMMARY_MODEL=meta-llama/llama-3.1-8b-instruct:free

# AssemblyAI Configuration (for accurate speaker diarization)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Speaker Diarization Service Configuration (optional - for local Pyannote)
HUGGINGFACE_TOKEN=your_huggingface_token_here
DIARIZATION_PORT=5000
DIARIZATION_URL=http://localhost:5000
